---
---

<section class="section cta-band" aria-labelledby="cta-title">
  <div class="container">
    <div class="cta" data-reveal>
      <div class="cta__glow" aria-hidden="true"></div>
      <p class="eyebrow">Get involved</p>
      <h2 id="cta-title" class="cta__title">
        Be part of something <span class="text-gold">that matters.</span>
      </h2>
      <p class="cta__lead lead">
        Economic Sentinel is growing — and we need ambitious students who want
        to write, design, code, and coordinate alongside us.
      </p>
      <div class="cta__actions">
        <a href="/join" class="btn btn-primary">
          Join the team
          <span class="arrow" aria-hidden="true">→</span>
        </a>
        <a href="/about" class="btn btn-ghost">Learn about us</a>
      </div>
      <p class="cta__fine text-muted">
        Remote-friendly across Pakistan · Youth-led · All roles welcome
      </p>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    text-align: center;
    padding: clamp(2.75rem, 7vw, 5.5rem) clamp(1.5rem, 5vw, 4rem);
    border: 1px solid rgba(227, 177, 103, 0.28);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(120% 140% at 50% -20%, rgba(227, 177, 103, 0.14), transparent 55%),
      linear-gradient(180deg, var(--es-surface), var(--es-base));
  }
  .cta__glow {
    position: absolute;
    top: -40%;
    left: 50%;
    width: 70%;
    height: 90%;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(227, 177, 103, 0.18), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }
  .cta .eyebrow {
    justify-content: center;
  }
  .cta .eyebrow::before {
    display: none;
  }
  .cta__title {
    font-size: var(--fs-h1);
    margin: 1rem auto 1.25rem;
    max-width: 18ch;
  }
  .cta__lead {
    max-width: 52ch;
    margin: 0 auto 2rem;
    color: var(--es-cream);
    opacity: 0.85;
  }
  .cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    justify-content: center;
  }
  .cta__fine {
    margin-top: 1.75rem;
    font-size: var(--fs-small);
  }
</style>
