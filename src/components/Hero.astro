---
// Hero — manifesto statement + ambient compass-field canvas.
// The canvas + GSAP entrance are progressive enhancements loaded client-side.
---

<section class="hero" data-hero>
  <canvas class="hero__canvas" data-hero-canvas aria-hidden="true"></canvas>
  <div class="hero__veil" aria-hidden="true"></div>

  <div class="container hero__inner">
    <p class="eyebrow hero__eyebrow" data-hero-eyebrow>
      Financial literacy · Youth empowerment · Pakistan
    </p>

    <h1 class="hero__title">
      <span class="hero__line" data-hero-line>
        <span class="word">We</span> <span class="word">arm</span>
        <span class="word">a</span> <span class="word">generation</span>
      </span>
      <span class="hero__line" data-hero-line>
        <span class="word">to</span> <span class="word text-gold">read</span>
        <span class="word text-gold">the</span> <span class="word text-gold">economy</span>
      </span>
      <span class="hero__line" data-hero-line>
        <span class="word">—</span> <span class="word">and</span>
        <span class="word">rewrite</span> <span class="word">it.</span>
      </span>
    </h1>

    <p class="hero__lead lead" data-hero-lead>
      Economic Sentinel is a youth-led organization bridging the gap between
      financial literacy and young people. Through seminars, student research,
      and a structured internship program, we empower the next generation to
      understand — and shape — the economy.
    </p>

    <div class="hero__actions" data-hero-actions>
      <a href="/internship" class="btn btn-primary">
        Apply to the Research Internship
        <span class="arrow" aria-hidden="true">→</span>
      </a>
      <a href="/research" class="btn btn-ghost">Explore our work</a>
    </div>
  </div>

  <a href="#pillars" class="hero__scroll" aria-label="Scroll to learn more" data-hero-scroll>
    <span class="hero__scroll-text">Scroll</span>
    <span class="hero__scroll-line" aria-hidden="true"></span>
  </a>
</section>

<script>
  import { initHeroCanvas } from '../scripts/hero-canvas';
  import { initHeroIntro } from '../scripts/hero-intro';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const canvas = document.querySelector<HTMLCanvasElement>('[data-hero-canvas]');
  if (canvas) initHeroCanvas(canvas, reduce);
  initHeroIntro(reduce);
</script>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-block: 8rem 6rem;
    overflow: hidden;
    isolation: isolate;
  }
  .hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
  }
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(60% 50% at 50% 38%, transparent, rgba(10, 15, 22, 0.55) 100%),
      linear-gradient(180deg, rgba(10, 15, 22, 0.2), transparent 30%, var(--es-base));
  }
  .hero__inner {
    position: relative;
  }
  .hero__eyebrow {
    margin-bottom: 1.75rem;
  }
  .hero__title {
    font-size: var(--fs-hero);
    font-weight: 400;
    max-width: 16ch;
  }
  .hero__line {
    display: block;
    overflow: hidden;
  }
  .word {
    display: inline-block;
  }
  .hero__lead {
    margin-top: 1.75rem;
    max-width: 46ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.5rem;
  }

  .hero__scroll {
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    color: var(--es-muted);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .hero__scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(var(--es-gold), transparent);
    position: relative;
    overflow: hidden;
  }
  .hero__scroll-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--es-gold-light);
    animation: scroll-cue 2.2s var(--ease-in-out) infinite;
  }
  @keyframes scroll-cue {
    0% { transform: translateY(-100%); }
    60%, 100% { transform: translateY(100%); }
  }

  @media (max-width: 600px) {
    .hero__scroll { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line::after { animation: none; }
  }
</style>
